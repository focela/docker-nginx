#!/bin/bash
#----------------------------------------------------------------------
# Nginx Maintenance Mode Management Script
#
# Purpose: Manages nginx maintenance mode by toggling between normal
# operation and maintenance page display. Supports permanent and
# temporary maintenance modes with configurable duration.
#
# Usage: maintenance (on|off|sleep NUM VALUE)
#
# Location: /usr/sbin/maintenance (installed in container)
# Author: Docker Nginx Project
#----------------------------------------------------------------------

# Enable strict error handling
set -euo pipefail

#----------------------------------------------------------------------
# CONFIGURATION
#----------------------------------------------------------------------
# Nginx configuration file path
readonly NGINX_CONF="/etc/nginx/nginx.conf"

# Default sleep duration for temporary maintenance (in minutes)
readonly DEFAULT_SLEEP_MINUTES=15

#----------------------------------------------------------------------
# UTILITY FUNCTIONS
#----------------------------------------------------------------------
# Display usage information and examples
show_usage() {
  cat << EOF
Usage: maintenance (on|off|sleep NUM VALUE)

Examples:
  maintenance on                     - Switches on Maintenance Mode
  maintenance off                    - Switches off Maintenance Mode
  maintenance sleep                  - Switches on Maintenance Mode temporarily for 15 minutes
  maintenance sleep 10 min           - Switches on Maintenance Mode temporarily for 10 minutes

Valid TIME VALUES:
  seconds (sec, secs)
  minutes (min, mins)
  hours (hour, hr, hrs)
  days (day, days)

EOF
}

# Enable maintenance mode by commenting out sites and enabling maintenance template
enable_maintenance() {
  # Comment out sites.enabled include to disable normal sites
  sed -i "s|include /etc/nginx/sites.enabled/\*.conf;|#include /etc/nginx/sites.enabled/\*.conf;|g" "${NGINX_CONF}"

  # Uncomment maintenance template include to enable maintenance page
  sed -i "s|#include /etc/nginx/templates/maintenance.template;|include /etc/nginx/templates/maintenance.template;|g" "${NGINX_CONF}"

  # Reload nginx configuration to apply changes
  nginx -s reload
}

# Disable maintenance mode by uncommenting sites and disabling maintenance template
disable_maintenance() {
  # Uncomment sites.enabled include to enable normal sites
  sed -i "s|#include /etc/nginx/sites.enabled/\*.conf;|include /etc/nginx/sites.enabled/\*.conf;|g" "${NGINX_CONF}"

  # Comment out maintenance template include to disable maintenance page
  sed -i "s|include /etc/nginx/templates/maintenance.template;|#include /etc/nginx/templates/maintenance.template;|g" "${NGINX_CONF}"

  # Reload nginx configuration to apply changes
  nginx -s reload
}

# Calculate sleep duration in seconds based on time value and unit
calculate_sleep_seconds() {
  local time_value="$1"
  local time_unit="$2"
  local sleep_seconds=0

  case "${time_unit,,}" in
    "min" | "minutes")
      sleep_seconds=$((time_value * 60))
      ;;
    "seconds" | "secs" | "sec")
      sleep_seconds=$((time_value * 1))
      ;;
    "hour" | "hours" | "hr" | "hrs")
      sleep_seconds=$((time_value * 3600))
      ;;
    "day" | "days")
      sleep_seconds=$((time_value * 86400))
      ;;
    *)
      echo "Error: Invalid time unit '${time_unit}'" >&2
      exit 1
      ;;
  esac

  echo "${sleep_seconds}"
}

# Get human-readable time unit description
get_time_description() {
  local time_unit="$1"

  case "${time_unit,,}" in
    "min" | "minutes")
      echo "minutes"
      ;;
    "seconds" | "secs" | "sec")
      echo "seconds"
      ;;
    "hour" | "hours" | "hr" | "hrs")
      echo "hour(s)"
      ;;
    "day" | "days")
      echo "day(s)"
      ;;
    *)
      echo "time unit(s)"
      ;;
  esac
}

#----------------------------------------------------------------------
# MAIN EXECUTION
#----------------------------------------------------------------------
# Check if argument is provided
if [ -z "${1:-}" ]; then
  show_usage
  exit 1
fi

# Process maintenance mode command
case "${1,,}" in
  "on" | "true")
    enable_maintenance
    echo "Maintenance Mode Activated"
    ;;

  "off" | "false")
    disable_maintenance
    echo "Maintenance Mode Deactivated"
    ;;

  "sleep" | "temp")
    # Set default values for temporary maintenance
    sleep_num="${2:-$DEFAULT_SLEEP_MINUTES}"
    sleep_unit="${3:-min}"

    # Enable maintenance mode
    enable_maintenance

    # Calculate sleep duration in seconds
    sleep_calc=$(calculate_sleep_seconds "${sleep_num}" "${sleep_unit}")
    sleep_desc=$(get_time_description "${sleep_unit}")

    echo "Maintenance Mode Temporarily Activated for ${sleep_num} ${sleep_desc}"

    # Sleep for specified duration
    sleep "${sleep_calc}"

    # Disable maintenance mode after sleep
    disable_maintenance
    echo "Maintenance Mode Deactivated"
    ;;

  *)
    echo "Error: Invalid command '${1}'" >&2
    show_usage
    exit 1
    ;;
esac
