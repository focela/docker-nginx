#!/command/with-contenv bash
#----------------------------------------------------------------------
# Nginx Configuration Auto-Reload Service Runner
#
# Purpose: Monitors nginx configuration files for changes and automatically
# reloads nginx configuration when modifications are detected. This enables
# zero-downtime configuration updates by watching key nginx directories.
#
# Usage: Executed automatically by s6-overlay when the nginx-config-reload
# service is enabled. Runs continuously monitoring for file changes until
# a change is detected, then reloads and exits.
#----------------------------------------------------------------------

# Enable strict error handling
set -euo pipefail

#----------------------------------------------------------------------
# CONFIGURATION
#----------------------------------------------------------------------
# Source container functions library
source /assets/functions/00-container

# Prepare service with default settings and dependency on main nginx service
prepare_service defaults 10-nginx
PROCESS_NAME="nginx-config-reload"

#----------------------------------------------------------------------
# MAIN EXECUTION
#----------------------------------------------------------------------
# Wait for container initialization to complete
check_container_initialized

# Wait for service-specific initialization to complete
check_service_initialized init

# Signal that pre-start checks are complete
liftoff

# Monitor nginx configuration files for changes
# Watches multiple directories and files that affect nginx configuration:
# - /etc/nginx/nginx.conf: Main nginx configuration file
# - /etc/nginx/sites.enabled: Directory containing enabled site configurations
# - /etc/nginx/snippets: Directory containing configuration snippets
# - ${NGINX_INCLUDE_CONFIGURATION}: Custom include configuration (if specified)
#
# Events monitored:
# - create: New files created
# - delete: Files removed
# - modify: File content changes
# - attrib: File attribute changes (permissions, timestamps)
while inotifywait -q -e create,delete,modify,attrib /etc/nginx/nginx.conf /etc/nginx/sites.enabled /etc/nginx/snippets "${NGINX_INCLUDE_CONFIGURATION}"; do
  print_info "Reloading Nginx configuration do to a detected change"

  # Reload nginx configuration gracefully (no downtime)
  # Uses nginx's built-in reload signal to apply configuration changes
  nginx -s reload

  # Exit after one reload cycle
  # Service will be restarted by s6-overlay to continue monitoring
  exit 0
done
