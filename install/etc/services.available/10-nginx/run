#!/command/with-contenv bash
#----------------------------------------------------------------------
# Nginx Service Runner Script
#
# Purpose: Starts the nginx web server process as a supervised service
# within the container. This script is executed by the s6-overlay
# service supervisor to manage the nginx daemon lifecycle.
#
# Usage: Executed automatically by s6-overlay when the nginx service
# is started. Ensures proper initialization order and dependency
# resolution before launching the nginx process.
#----------------------------------------------------------------------

# Enable strict error handling
set -euo pipefail

#----------------------------------------------------------------------
# CONFIGURATION
#----------------------------------------------------------------------
# Source container functions library
source /assets/functions/00-container

# Set process name for logging and monitoring
PROCESS_NAME="nginx"

#----------------------------------------------------------------------
# MAIN EXECUTION
#----------------------------------------------------------------------
# Wait for container initialization to complete
# This ensures all init scripts have finished before starting nginx
check_container_initialized

# Wait for service-specific initialization to complete
# This ensures nginx configuration is ready before starting the daemon
check_service_initialized init

# Signal that pre-start checks are complete
liftoff

# Start nginx daemon
print_start "Starting nginx ${NGINX_VERSION}"

# Execute nginx daemon, replacing this process
# Using 'exec' ensures proper signal handling and process supervision
exec nginx
