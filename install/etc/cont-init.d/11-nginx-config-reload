#!/command/with-contenv bash
#----------------------------------------------------------------------
# Nginx Configuration Auto-Reload Service
#
# Purpose: Manages automatic reloading of Nginx configuration when
# configuration files change. This service monitors file changes and
# triggers nginx reload to apply configuration updates without downtime.
#
# Usage: Executed during container initialization to enable or disable
# the nginx configuration auto-reload functionality based on environment
# variable NGINX_RELOAD_ON_CONFIG_CHANGE.
#----------------------------------------------------------------------

# Enable strict error handling
set -euo pipefail

#----------------------------------------------------------------------
# CONFIGURATION
#----------------------------------------------------------------------
# Source container functions library
source /assets/functions/00-container

# Prepare service with dependency on main nginx service (10-nginx)
prepare_service 10-nginx
PROCESS_NAME="nginx-config-reload"

#----------------------------------------------------------------------
# MAIN EXECUTION
#----------------------------------------------------------------------
# Configure nginx configuration auto-reload based on environment setting
if var_true "${NGINX_RELOAD_ON_CONFIG_CHANGE}" ; then
  print_notice "Enabling Auto Reload of Nginx Configuration when configuration files change"
else
  # Stop the config reload service if auto-reload is disabled
  service_stop 11-nginx-config-reload
fi

# Signal completion of initialization
liftoff
