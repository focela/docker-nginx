#----------------------------------------------------------------------
# LemonLDAP::NG Authentication Request Configuration
#
# Purpose: Configures nginx to integrate with LemonLDAP::NG (LLNG) for
# centralized web single sign-on authentication. This snippet handles
# authentication subrequests and manages session cookies and redirects.
#
# Usage: Included in nginx server blocks or location blocks that require
# LLNG authentication protection. Works with auth_request module.
#----------------------------------------------------------------------

# Preserve original request URI with query parameters for post-auth redirect
# Combines base URI with query string separator and arguments
set $original_uri $uri$is_args$args;

# Perform authentication subrequest to LLNG handler
# Sends request to /lmauth endpoint for authentication validation
auth_request /lmauth;

# Extract authentication response headers and store in nginx variables
# These variables capture LLNG handler responses for session management

# Capture Set-Cookie header from LLNG for session management
auth_request_set $cookie_value $upstream_http_set_cookie;

# Capture redirect location for unauthenticated users (login page URL)
auth_request_set $lmlocation $upstream_http_location;

# Extract authenticated user identity from LLNG response
auth_request_set $lmremote_user $upstream_http_lm_remote_user;

# Extract custom user attributes from LLNG response (roles, groups, etc.)
auth_request_set $lmremote_custom $upstream_http_lm_remote_custom;

# Forward LLNG session cookie to client browser
# Maintains authentication state across requests
add_header Set-Cookie $cookie_value;

# Redirect unauthenticated requests (401) to LLNG login page
# Uses location header from LLNG handler response
error_page 401 $lmlocation;
